PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/iot_energy
MQTT_URL=mqtt://127.0.0.1:1883
CORS_ORIGIN=http://localhost:5173
SKIP_AUTH=false
JWT_SECRET=change-long-random-string-in-production
